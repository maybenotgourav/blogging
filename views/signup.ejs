<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Create account — Blogify</title>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include("./partials/nav") %>
    <main class="container form-page flex-grow-1 px-3 px-lg-4">
        <div class="form-card">
            <h1>Join Blogify</h1>
            <p class="lead">Create an account to write posts and join discussions.</p>
            <form action="/user/signup" method="post">
                <div class="mb-3">
                    <label for="fullName" class="form-label">Full name</label>
                    <input type="text" class="form-control" id="fullName" name="fullName" autocomplete="name" required>
                </div>
                <div class="mb-3">
                    <label for="signup-email" class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" id="signup-email" autocomplete="email" required>
                </div>
                <div class="mb-4">
                    <label for="signup-password" class="form-label">Password</label>
                    <input name="password" type="password" class="form-control" id="signup-password" autocomplete="new-password" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Create account</button>
            </form>
            <p class="auth-switch mb-0">
                Already have an account? <a href="/user/signin">Sign in</a>
            </p>
        </div>
    </main>
    <%- include("./partials/footer") %>
    <%- include("./partials/scripts") %>
</body>
</html>
