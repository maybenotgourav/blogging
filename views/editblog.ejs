<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Edit post — Blogify</title>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include("./partials/nav") %>
    <main class="container form-page flex-grow-1 px-3 px-lg-4">
        <div class="form-card">
            <h1>Edit post</h1>
            <p class="lead">Update the title, body, or upload a new cover image (optional).</p>
            <form action="/blog/edit/<%= blog._id %>" method="post" enctype="multipart/form-data">
                <div class="mb-4">
                    <label for="CoverImage" class="form-label">New cover image <span class="text-muted fw-normal">(optional)</span></label>
                    <input type="file" class="form-control" id="CoverImage" name="CoverImage" accept="image/*">
                    <div class="form-text">Leave empty to keep the current cover.</div>
                </div>
                <div class="mb-4">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" id="title" name="title" value="<%= blog.title %>" required>
                </div>
                <div class="mb-4">
                    <label for="body" class="form-label">Body</label>
                    <textarea name="body" class="form-control" id="body" rows="12" required><%= blog.body %></textarea>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a href="/blog/<%= blog._id %>" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </main>
    <%- include("./partials/footer") %>
    <%- include("./partials/scripts") %>
</body>
</html>
