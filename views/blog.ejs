<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= blog.title %> — Blogify</title>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include("./partials/nav") %>
    <main class="container flex-grow-1 px-3 px-lg-4 pb-5">
        <article class="article-hero">
            <div class="article-hero__cover">
                <img src="<%= blog.coverImageURL || '/images/download.jpg' %>" alt="" loading="lazy" onerror="this.src='/images/download.jpg'">
            </div>
            <% if (locals.canEdit || locals.canDelete) { %>
            <div class="article-actions d-flex flex-wrap justify-content-end gap-2 mb-2">
                <% if (locals.canEdit) { %>
                <a href="/blog/edit/<%= blog._id %>" class="btn btn-outline-secondary btn-sm">Edit article</a>
                <% } %>
                <% if (locals.canDelete) { %>
                <form action="/blog/delete/<%= blog._id %>" method="post" class="d-inline" onsubmit="return confirm('Delete this post permanently? This cannot be undone.');">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete post</button>
                </form>
                <% } %>
            </div>
            <% } %>
            <h1 class="article-title"><%= blog.title %></h1>
            <div class="article-body"><%= blog.body %></div>
        </article>

        <div class="author-card">
            <img src="<%= blog.createdBy && blog.createdBy.profilePicture ? blog.createdBy.profilePicture : '/images/download.jpg' %>" alt="" onerror="this.src='/images/download.jpg'">
            <div>
                <p class="author-name"><%= blog.createdBy && blog.createdBy.fullName ? blog.createdBy.fullName : 'Author' %></p>
                <p class="author-label">Author</p>
            </div>
        </div>

        <section class="comments-section" aria-labelledby="comments-heading">
            <h2 id="comments-heading">Comments</h2>

            <% if (locals.user) { %>
                <div class="comment-form-card">
                    <form action="/blog/comment/<%= blog._id %>" method="post">
                        <label for="comment-content" class="form-label">Add a comment</label>
                        <textarea class="form-control mb-3" name="content" id="comment-content" rows="3" placeholder="Share your thoughts…" required></textarea>
                        <button class="btn btn-primary" type="submit">Post comment</button>
                    </form>
                </div>
            <% } else { %>
                <p class="comments-signin-hint mb-4">
                    <a href="/user/signin">Sign in</a> to join the conversation.
                </p>
            <% } %>

            <% if (comments && comments.length > 0) { %>
                <ul class="comment-list">
                    <% comments.forEach((c) => { %>
                        <li class="comment-item">
                            <div class="comment-meta">
                                <%= c.createdBy && c.createdBy.fullName ? c.createdBy.fullName : 'Reader' %>
                                <% if (c.createdAt) { %>
                                    <span class="text-muted fw-normal"> · <%= new Date(c.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                <% } %>
                            </div>
                            <p><%= c.content %></p>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="text-muted mb-0">No comments yet. Start the thread above.</p>
            <% } %>
        </section>
    </main>
    <%- include("./partials/footer") %>
    <%- include("./partials/scripts") %>
</body>
</html>
